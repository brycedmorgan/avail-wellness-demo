---
layout: base.njk
title: Dashboard
subtitle: Welcome back! Here's your health optimization summary.
---

<!-- Progress Overview -->
<div class="dashboard-hero">
    <div class="progress-overview-card">
        <div class="progress-highlights">
            <div class="progress-item">
                <div class="progress-number">{{ patient.labResults[0].highlights.totalTestosterone.change }}</div>
                <div class="progress-label">Testosterone Increase</div>
            </div>
            <div class="progress-item">
                <div class="progress-number">+9.8 lbs</div>
                <div class="progress-label">Lean Mass Gained</div>
            </div>
            <div class="progress-item">
                <div class="progress-number">-9.8%</div>
                <div class="progress-label">Body Fat Lost</div>
            </div>
        </div>
        <div class="progress-details">
            <h3>Strong progress, {{ patient.patient.name.split(' ')[0] }}.</h3>
            <p>Your hormone optimization journey is delivering amazing results. Every metric shows consistent improvement since starting with Avail Wellness.</p>
        </div>
    </div>
</div>

<!-- Key Metrics Grid -->
<div class="metrics-grid">
    <div class="metric-card">
        <div class="metric-header">
            <h4>Total Testosterone</h4>
            <span class="trend-indicator up">{{ patient.labResults[0].highlights.totalTestosterone.trend | trendArrow }}</span>
        </div>
        <div class="metric-value">
            {{ patient.labResults[0].highlights.totalTestosterone.value }} 
            <span class="metric-unit">{{ patient.labResults[0].highlights.totalTestosterone.unit }}</span>
        </div>
        <div class="metric-change positive">{{ patient.labResults[0].highlights.totalTestosterone.change }}</div>
        <div class="metric-range">Range: {{ patient.labResults[0].highlights.totalTestosterone.range }}</div>
    </div>

    <div class="metric-card">
        <div class="metric-header">
            <h4>Free Testosterone</h4>
            <span class="trend-indicator up">{{ patient.labResults[0].highlights.freeTestosterone.trend | trendArrow }}</span>
        </div>
        <div class="metric-value">
            {{ patient.labResults[0].highlights.freeTestosterone.value }}
            <span class="metric-unit">{{ patient.labResults[0].highlights.freeTestosterone.unit }}</span>
        </div>
        <div class="metric-change positive">{{ patient.labResults[0].highlights.freeTestosterone.change }}</div>
        <div class="metric-range">Range: {{ patient.labResults[0].highlights.freeTestosterone.range }}</div>
    </div>

    <div class="metric-card">
        <div class="metric-header">
            <h4>Body Fat</h4>
            <span class="trend-indicator down">↘</span>
        </div>
        <div class="metric-value">
            {{ patient.bodyComposition[0].bodyFatPercentage }}
            <span class="metric-unit">%</span>
        </div>
        <div class="metric-change positive">-9.8% from baseline</div>
        <div class="metric-range">Excellent improvement</div>
    </div>

    <div class="metric-card">
        <div class="metric-header">
            <h4>Supplement Adherence</h4>
            <span class="trend-indicator up">↗</span>
        </div>
        <div class="metric-value">
            {{ patient.supplements.adherence.lastMonth }}
            <span class="metric-unit">%</span>
        </div>
        <div class="metric-change positive">+3% this month</div>
        <div class="metric-range">Target: >90%</div>
    </div>
</div>

<!-- Comprehensive Lab Trends -->
<div class="dashboard-section">
    <h3>Your Lab Progress Over Time</h3>
    <div class="lab-trends-container">
        <div class="chart-container">
            <canvas id="labTrendsChart"></canvas>
        </div>
        
        <div class="current-values">
            <div class="value-card testosterone">
                <div class="value-header">
                    <h4>Total Testosterone</h4>
                    <span class="trend-up">+204%</span>
                </div>
                <div class="value-number">853 ng/dl</div>
                <div class="value-range">Range: 238-1048</div>
                <div class="value-status excellent">Optimized</div>
            </div>
            
            <div class="value-card a1c">
                <div class="value-header">
                    <h4>Hemoglobin A1C</h4>
                    <span class="trend-down">-0.2</span>
                </div>
                <div class="value-number">5.4%</div>
                <div class="value-range">Target: <5.7%</div>
                <div class="value-status good">Good Progress</div>
            </div>
            
            <div class="value-card vitamin-d">
                <div class="value-header">
                    <h4>Vitamin D</h4>
                    <span class="trend-up">+28</span>
                </div>
                <div class="value-number">52 ng/ml</div>
                <div class="value-range">Target: 30-100</div>
                <div class="value-status good">Optimal</div>
            </div>
            
            <div class="value-card thyroid">
                <div class="value-header">
                    <h4>Free T4</h4>
                    <span class="trend-stable">Stable</span>
                </div>
                <div class="value-number">1.3 ng/dl</div>
                <div class="value-range">Range: 0.8-1.8</div>
                <div class="value-status good">Normal</div>
            </div>
        </div>
    </div>
</div>

<!-- Upcoming Appointments (Priority) -->
<div class="dashboard-section">
    <h3>Upcoming Appointments</h3>
    <div class="appointment-card">
        <div class="appointment-date">
            <div class="date-month">APR</div>
            <div class="date-day">15</div>
        </div>
        <div class="appointment-details">
            <h4>{{ patient.appointments.upcoming[0].type }}</h4>
            <p>{{ patient.appointments.upcoming[0].time }} with {{ patient.appointments.upcoming[0].provider }}</p>
            <p class="appointment-purpose">{{ patient.appointments.upcoming[0].purpose }}</p>
        </div>
        <div class="appointment-actions">
            <button class="btn btn-outline">Reschedule</button>
            <button class="btn btn-primary">Join Video Call</button>
        </div>
    </div>
</div>

<!-- Provider Messaging (Prominent) -->
<div class="dashboard-section messaging-section">
    <div class="messaging-header">
        <div class="provider-info">
            <div class="provider-avatar">BW</div>
            <div class="provider-details">
                <h3>Message Your Provider</h3>
                <p>Brooke Welsh, WHNP • Typically responds within 4 hours</p>
            </div>
        </div>
        <button class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="margin-right: 8px;">
                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
            Send Message
        </button>
    </div>
    <div class="recent-messages">
        <div class="message-preview">
            <strong>Latest from Brooke:</strong> "Your latest lab results look excellent! The testosterone optimization is working perfectly. See you at your follow-up next month."
        </div>
    </div>
</div>

<!-- Upload Lab Results & Scans -->
<div class="dashboard-section">
    <h3>Upload Results & Scans</h3>
    <div class="upload-grid">
        <div class="upload-card">
            <div class="upload-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M9 2v3h2V2h2v3h2V2h2v5H7V2h2zm8 8.5c0 .55-.45 1-1 1s-1-.45-1-1 .45-1 1-1 1 .45 1 1z"/>
                </svg>
            </div>
            <div class="upload-content">
                <h4>Lab Results</h4>
                <p>Upload PDF lab reports or photos of lab printouts</p>
                <button class="btn btn-outline btn-sm">Choose Files</button>
            </div>
        </div>
        
        <div class="upload-card">
            <div class="upload-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
            </div>
            <div class="upload-content">
                <h4>DEXA Scans</h4>
                <p>Upload body composition DEXA scan results</p>
                <button class="btn btn-outline btn-sm">Choose Files</button>
            </div>
        </div>
        
        <div class="upload-card">
            <div class="upload-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17l-3-3 1.41-1.41L9 14.17l7.59-7.59L18 8l-9 9z"/>
                </svg>
            </div>
            <div class="upload-content">
                <h4>Body Fat Scans</h4>
                <p>Upload InBody, BodPod, or other body composition results</p>
                <button class="btn btn-outline btn-sm">Choose Files</button>
            </div>
        </div>
        
        <div class="upload-card">
            <div class="upload-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 2 2h8c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/>
                </svg>
            </div>
            <div class="upload-content">
                <h4>Other Reports</h4>
                <p>Upload any other health reports, imaging, or test results</p>
                <button class="btn btn-outline btn-sm">Choose Files</button>
            </div>
        </div>
    </div>
    <div class="upload-note">
        <p><strong>Secure Upload:</strong> All files are encrypted and only shared with your Avail Wellness providers. Supported formats: PDF, JPG, PNG, DICOM.</p>
    </div>
</div>

<!-- Recent Activity & Quick Actions -->
<div class="dashboard-grid">
    <div class="dashboard-section">
        <h3>Recent Activity</h3>
        <div class="activity-feed">
            <div class="activity-item">
                <svg class="activity-icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M9 2v3h2V2h2v3h2V2h2v5H7V2h2zm8 8.5c0 .55-.45 1-1 1s-1-.45-1-1 .45-1 1-1 1 .45 1 1z"/>
                </svg>
                <div class="activity-content">
                    <div class="activity-title">Lab Results Available</div>
                    <div class="activity-date">{{ patient.labResults[0].date | dateFormat }}</div>
                    <div class="activity-summary">Testosterone optimization results show excellent response</div>
                </div>
                <a href="/labs/" class="activity-action">View Details</a>
            </div>
            
            <div class="activity-item">
                <svg class="activity-icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M3.5 6L2 7.5 7.5 13 2 18.5 3.5 20l5.5-5.5L14.5 20 16 18.5 10.5 13 16 7.5 14.5 6 9 11.5 3.5 6z"/>
                </svg>
                <div class="activity-content">
                    <div class="activity-title">Supplement Protocol Updated</div>
                    <div class="activity-date">March 15, 2026</div>
                    <div class="activity-summary">Added Zinc and Magnesium to evening routine</div>
                </div>
