            </div>
            
            <div class="activity-item">
                <svg class="activity-icon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M19 8h-2v3h-3v2h3v3h2v-3h3v-2h-3V8zM4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6z"/>
                </svg>
                <div class="activity-content">
                    <div class="activity-title">Pellet Treatment</div>
                    <div class="activity-date">{{ patient.treatments[0].date | dateFormat }}</div>
                    <div class="activity-summary">Testosterone pellet insertion completed successfully</div>
                </div>
                <a href="/treatments/" class="activity-action">View Details</a>
            </div>
        </div>
    </div>

    <div class="dashboard-section">
        <h3>Quick Actions</h3>
        <div class="quick-actions">
            <a href="/treatments/" class="action-card">
                <svg class="action-icon" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M19 8h-2v3h-3v2h3v3h2v-3h3v-2h-3V8zM4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H8V4h12v12z"/>
                </svg>
                <div class="action-title">View Treatments</div>
                <div class="action-subtitle">Track your protocol</div>
            </a>
            
            <a href="/labs/" class="action-card">
                <svg class="action-icon" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M9 2v3h2V2h2v3h2V2h2v5H7V2h2zm8 8.5c0 .55-.45 1-1 1s-1-.45-1-1 .45-1 1-1 1 .45 1 1z"/>
                </svg>
                <div class="action-title">View Latest Labs</div>
                <div class="action-subtitle">February 19, 2026 results</div>
            </a>
            
            <a href="/supplements/" class="action-card">
                <svg class="action-icon" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M3.5 6L2 7.5 7.5 13 2 18.5 3.5 20l5.5-5.5L14.5 20 16 18.5 10.5 13 16 7.5 14.5 6 9 11.5 3.5 6z"/>
                </svg>
                <div class="action-title">View Supplements</div>
                <div class="action-subtitle">Review your protocol</div>
            </a>
            
            <a href="/body-composition/" class="action-card">
                <svg class="action-icon" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M5 9.2h3V19H5zM10.6 5h2.8v14h-2.8zm5.6 8H19v6h-2.8z"/>
                </svg>
                <div class="action-title">View Body Comp</div>
                <div class="action-subtitle">DEXA + InBody trends</div>
            </a>
        </div>
    </div>
</div>



<script>
// Symptom Improvement Chart (only render if the canvas is on the page)
const symptomCanvas = document.getElementById('symptomChart');
if (symptomCanvas) {
const ctx = symptomCanvas.getContext('2d');
const symptomChart = new Chart(ctx, {
    type: 'radar',
    data: {
        labels: ['Energy', 'Sleep', 'Libido', 'Mood', 'Focus'],
        datasets: [{
            label: 'Baseline (Pre-Treatment)',
            data: [{{ patient.symptoms.baseline.energy }}, {{ patient.symptoms.baseline.sleep }}, {{ patient.symptoms.baseline.libido }}, {{ patient.symptoms.baseline.mood }}, {{ patient.symptoms.baseline.focus }}],
            backgroundColor: 'rgba(156, 163, 175, 0.1)',
            borderColor: 'rgba(156, 163, 175, 0.8)',
            borderWidth: 2
        }, {
            label: 'Current (Post-Treatment)',
            data: [{{ patient.symptoms.current.energy }}, {{ patient.symptoms.current.sleep }}, {{ patient.symptoms.current.libido }}, {{ patient.symptoms.current.mood }}, {{ patient.symptoms.current.focus }}],
            backgroundColor: 'rgba(107, 142, 90, 0.1)',
            borderColor: 'rgba(107, 142, 90, 0.8)',
            borderWidth: 2
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
            r: {
                beginAtZero: true,
                max: 10,
                ticks: {
                    stepSize: 2
                }
            }
        },
        plugins: {
            legend: {
                position: 'bottom'
            }
        }
    }
});
}

// Comprehensive Lab Trends Chart
const labTrendsCtx = document.getElementById('labTrendsChart').getContext('2d');
const labTrendsChart = new Chart(labTrendsCtx, {
    type: 'line',
    data: {
        labels: ['Baseline (Mar 2025)', 'Sep 2025', 'Dec 2025', 'Feb 2026'],
        datasets: [{
            label: 'Testosterone (ng/dl)',
            data: [281, 586, 703, 853],
            backgroundColor: 'rgba(107, 142, 90, 0.1)',
            borderColor: 'rgba(107, 142, 90, 0.8)',
            borderWidth: 3,
            fill: false,
            tension: 0.4,
            pointBackgroundColor: 'rgba(107, 142, 90, 1)',
            pointBorderColor: 'white',
            pointBorderWidth: 2,
            pointRadius: 6,
            yAxisID: 'y'
        }, {
            label: 'A1C (%)',
            data: [5.6, 5.6, 5.5, 5.4],
            backgroundColor: 'rgba(184, 160, 130, 0.1)',
            borderColor: 'rgba(184, 160, 130, 0.8)',
            borderWidth: 3,
            fill: false,
            tension: 0.4,
            pointBackgroundColor: 'rgba(184, 160, 130, 1)',
            pointBorderColor: 'white',
            pointBorderWidth: 2,
            pointRadius: 6,
            yAxisID: 'y1'
        }, {
            label: 'Vitamin D (ng/ml)',
            data: [24, 38, 46, 52],
            backgroundColor: 'rgba(47, 79, 79, 0.1)',
            borderColor: 'rgba(47, 79, 79, 0.8)',
            borderWidth: 3,
            fill: false,
            tension: 0.4,
            pointBackgroundColor: 'rgba(47, 79, 79, 1)',
            pointBorderColor: 'white',
            pointBorderWidth: 2,
            pointRadius: 6,
            yAxisID: 'y2'
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                position: 'bottom'
            }
        },
        scales: {
            x: {
                grid: { display: false }
            },
            y: {
                type: 'linear',
                display: true,
                position: 'left',
                title: {
                    display: true,
                    text: 'Testosterone (ng/dl)'
                },
                min: 200,
                max: 900
            },
            y1: {
                type: 'linear',
                display: true,
                position: 'right',
                title: {
                    display: true,
                    text: 'A1C (%) / Vit D (ng/ml)'
                },
                min: 0,
                max: 60,
                grid: { drawOnChartArea: false }
            },
            y2: {
                type: 'linear',
                display: false,
                min: 20,
                max: 60
            }
        }
    }
});
</script>

<style>
/* Progress Overview — warm gradient hero, real estate, real hierarchy */
.progress-overview-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 48px;
    background: linear-gradient(135deg, #B8A082 0%, #9C8366 60%, #6F5A47 100%);
    color: var(--white);
    padding: 36px 40px;
    border-radius: 14px;
    overflow: hidden;
    position: relative;
}

.progress-overview-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(80% 60% at 100% 0%, rgba(255,255,255,0.15), transparent 60%);
    pointer-events: none;
}

.progress-highlights {
    display: flex;
    gap: 36px;
    flex-shrink: 0;
    flex-wrap: wrap;
    order: 2;
    position: relative;
}

.progress-item {
    text-align: left;
    min-width: 96px;
}

.progress-number {
    font-size: 30px;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 8px;
    color: var(--white);
    letter-spacing: -0.025em;
    font-variant-numeric: tabular-nums;
}

.progress-label {
    font-size: 10.5px;
    color: rgba(255, 255, 255, 0.78);
    text-transform: uppercase;
    letter-spacing: 0.7px;
    line-height: 1.2;
    font-weight: 600;
}

.progress-details {
    order: 1;
    position: relative;
}

.progress-details h3 {
    margin: 0 0 8px;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--white);
    letter-spacing: -0.025em;
    line-height: 1.2;
}

.progress-details p {
    margin: 0;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.55;
    font-size: 0.95rem;
    max-width: 52ch;
}

/* Lab Trends Styles */
.lab-trends-container {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(260px, 1fr);
    gap: 32px;
    align-items: start;
}

.lab-trends-container > .chart-container,
.lab-trends-container > .current-values {
    min-width: 0;
}

.current-values {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.value-card {
    background: var(--white);
    padding: 20px;
    border-radius: 8px;
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
    border-left: 4px solid var(--avail-primary);
}

.value-card.testosterone {
    border-left-color: rgba(107, 142, 90, 1);
}

.value-card.a1c {
    border-left-color: rgba(184, 160, 130, 1);
}

.value-card.vitamin-d {
    border-left-color: rgba(47, 79, 79, 1);
}

.value-card.thyroid {
    border-left-color: rgba(156, 131, 102, 1);
}

.value-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
}

.value-header h4 {
    margin: 0;
    color: var(--avail-text-primary);
    font-weight: 600;
    font-size: 14px;
}

.trend-up {
    color: var(--avail-success);
    font-weight: 600;
    font-size: 12px;
}

.trend-down {
    color: var(--avail-success);
    font-weight: 600;
    font-size: 12px;
}

.trend-stable {
    color: var(--avail-text-light);
    font-weight: 500;
    font-size: 12px;
}

.value-number {
    font-size: 20px;
    font-weight: 700;
    color: var(--avail-text-primary);
    margin-bottom: 4px;
}

.value-range {
    color: var(--avail-text-light);
    font-size: 11px;
    margin-bottom: 6px;
}

.value-status {
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
}

.value-status.excellent {
    background: rgba(107, 142, 90, 0.1);
    color: var(--avail-success);
}

.value-status.good {
    background: rgba(59, 130, 246, 0.1);
    color: #2563EB;
}

@media (max-width: 1100px) {
    .lab-trends-container {
        grid-template-columns: 1fr;
        gap: 20px;
    }
}

@media (max-width: 768px) {
    .progress-overview-card {
        flex-direction: column;
        gap: 20px;
        text-align: center;
    }

    .progress-highlights {
        flex-wrap: wrap;
        justify-content: center;
    }
}

/* Upload Section Styles */
.upload-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-bottom: 16px;
}

.upload-card {
    background: var(--white);
    padding: 24px;
    border-radius: 8px;
    border: 2px dashed var(--gray-300);
    text-align: center;
    transition: all 0.2s ease;
    cursor: pointer;
}

.upload-card:hover {
    border-color: var(--avail-primary);
    background: var(--avail-bg-accent);
}

.upload-icon {
    color: var(--avail-primary);
    margin-bottom: 12px;
}

