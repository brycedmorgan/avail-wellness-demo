---
layout: admin.njk
title: Patient Management
subtitle: Complete patient database and care coordination
---

<!-- Patient Search & Filters -->
<div class="patient-controls">
    <div class="search-section">
        <div class="search-input">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
            </svg>
            <input type="text" placeholder="Search patients by name, email, or ID...">
        </div>
        <button class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
            </svg>
            Add New Patient
        </button>
    </div>
    
    <div class="filter-tabs">
        <button class="filter-tab active">All Patients ({{ adminData.patients.length }})</button>
        <button class="filter-tab">Active (4)</button>
        <button class="filter-tab">Needs Attention (2)</button>
        <button class="filter-tab">New This Month ({{ adminData.businessMetrics.newPatientsThisMonth }})</button>
        <button class="filter-tab">High Value (3)</button>
    </div>
</div>

<!-- Detailed Patient Table -->
<div class="patients-table-container">
    <table class="patients-table">
        <thead>
            <tr>
                <th>Patient</th>
                <th>Program & Duration</th>
                <th>Monthly Revenue</th>
                <th>Latest Labs</th>
                <th>Adherence</th>
                <th>Next Contact</th>
                <th>Status & Flags</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for patient in adminData.patients %}
            <tr class="patient-row" data-status="{{ patient.status | lower }}">
                <td>
                    <div class="patient-info">
                        <div class="patient-avatar">{{ patient.name.split(' ')[0][0] }}{{ patient.name.split(' ')[1][0] }}</div>
                        <div class="patient-details">
                            <div class="patient-name">{{ patient.name }}</div>
                            <div class="patient-meta">{{ patient.id }} • {{ patient.age }}{{ patient.gender[0] }} • Started {{ patient.treatmentStart | dateFormat }}</div>
                            <div class="patient-contact">patient@email.com</div>
                        </div>
                    </div>
                </td>
                <td>
                    <div class="program-info">
                        <div class="program-name">{{ patient.program }}</div>
                        <div class="program-duration">
                            6 months active
                        </div>
                    </div>
                </td>
                <td>
                    <div class="revenue-info">
                        <div class="revenue-amount">{{ patient.monthlyRevenue | currency }}/mo</div>
                        <div class="revenue-ltv">
                            LTV: $3,600
                        </div>
                    </div>
                </td>
                <td>
                    <div class="labs-status">
                        <div class="labs-date">{{ patient.recentLabs }}</div>
                        {% if patient.recentLabs == "Complete - Optimized" %}
                        <div class="labs-result good">Excellent Results</div>
                        {% elif patient.recentLabs == "Pending" %}
                        <div class="labs-result pending">Awaiting Results</div>
                        {% elif "Needs" in patient.recentLabs %}
                        <div class="labs-result needs-action">Requires Review</div>
                        {% else %}
                        <div class="labs-result overdue">Overdue</div>
                        {% endif %}
                    </div>
                </td>
                <td>
                    <div class="adherence-section">
                        <div class="adherence-bar">
                            <div class="adherence-fill" style="width: {{ patient.adherence }}%"></div>
                        </div>
                        <div class="adherence-score">{{ patient.adherence }}%</div>
                        {% if patient.adherence >= 90 %}
                        <div class="adherence-trend good">Excellent</div>
                        {% elif patient.adherence >= 75 %}
                        <div class="adherence-trend ok">Good</div>
                        {% else %}
                        <div class="adherence-trend poor">Needs Support</div>
                        {% endif %}
                    </div>
                </td>
                <td>
                    <div class="next-contact">
                        {% if patient.nextAppointment %}
                        <div class="contact-date">{{ patient.nextAppointment | dateFormat }}</div>
                        <div class="contact-type">Follow-up Visit</div>
                        {% else %}
                        <div class="contact-date">Not Scheduled</div>
                        <div class="contact-action">
                            <button class="btn btn-sm btn-outline">Schedule</button>
                        </div>
                        {% endif %}
                    </div>
                </td>
                <td>
                    <div class="status-section">
                        <div class="status-badge status-{{ patient.status | lower }}">{{ patient.status }}</div>
                        <div class="patient-flags">
                            {% for flag in patient.flags %}
                            <span class="flag-badge flag-{{ flag | replace(' ', '') | lower }}">{{ flag }}</span>
                            {% endfor %}
                        </div>
                    </div>
                </td>
                <td>
                    <div class="action-buttons">
                        <button class="action-btn primary" title="View Patient Portal">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                            </svg>
                        </button>
                        <button class="action-btn" title="Send Message">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                            </svg>
                        </button>
                        <button class="action-btn" title="Schedule Appointment">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.1 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"/>
                            </svg>
                        </button>
                        <button class="action-btn" title="View Lab Results">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M9 2v3h2V2h2v3h2V2h2v5H7V2h2zm8 8.5c0 .55-.45 1-1 1s-1-.45-1-1 .45-1 1-1 1 .45 1 1z"/>
                            </svg>
                        </button>
                        {% if patient.status == "Inactive" %}
                        <button class="action-btn warning" title="Re-engage Patient">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                            </svg>
                        </button>
                        {% endif %}
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<!-- Patient Analytics Summary -->
<div class="patient-analytics">
    <div class="analytics-grid">
        <div class="analytics-card">
            <h3>Patient Retention Analysis</h3>
            <div class="retention-metrics">
                <div class="metric">
                    <span class="metric-value">{{ adminData.businessMetrics.retentionRate }}%</span>
                    <span class="metric-label">12-Month Retention</span>
                </div>
                <div class="metric">
                    <span class="metric-value">{{ adminData.businessMetrics.averageRevenuePerPatient | currency }}</span>
                    <span class="metric-label">Avg Revenue/Patient</span>
                </div>
                <div class="metric">
                    <span class="metric-value">18 months</span>
                    <span class="metric-label">Avg Treatment Duration</span>
                </div>
            </div>
        </div>
        
        <div class="analytics-card">
            <h3>Treatment Outcomes Summary</h3>
            <div class="outcome-summary">
                <div class="outcome-stat">
                    <span class="outcome-label">Avg Testosterone Increase:</span>
                    <span class="outcome-value">{{ adminData.analytics.patientOutcomes.averageTestosteroneIncrease }}%</span>
                </div>
                <div class="outcome-stat">
                    <span class="outcome-label">Patient Satisfaction:</span>
                    <span class="outcome-value">{{ adminData.analytics.patientOutcomes.patientSatisfaction }}/5.0</span>
                </div>
                <div class="outcome-stat">
                    <span class="outcome-label">Symptom Improvement:</span>
                    <span class="outcome-value">{{ adminData.analytics.patientOutcomes.energyScoreImprovement }} points</span>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
/* Patient Management Styles */
.patient-controls {
  background: var(--white);
  padding: 24px;
  border-radius: 12px;
  box-shadow: var(--shadow-sm);
  margin-bottom: 24px;
  border: 1px solid var(--gray-200);
}

.search-section {
  display: flex;
  gap: 16px;
  align-items: center;
  margin-bottom: 20px;
}

.search-input {
  position: relative;
  flex: 1;
  max-width: 400px;
}

.search-input svg {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--gray-400);
}

.search-input input {
  width: 100%;
  padding: 12px 12px 12px 40px;
  border: 1px solid var(--gray-300);
  border-radius: 8px;
  font-size: 14px;
}

.search-input input:focus {
  outline: none;
  border-color: var(--avail-primary);
  box-shadow: 0 0 0 3px rgba(184, 160, 130, 0.1);
}

.filter-tabs {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.filter-tab {
  padding: 8px 16px;
  border: 1px solid var(--gray-300);
  background: var(--white);
  color: var(--gray-600);
  border-radius: 6px;
  font-size: 14px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.filter-tab.active,
.filter-tab:hover {
  background: var(--avail-primary);
  color: var(--white);
  border-color: var(--avail-primary);
}

.patients-table-container {
  background: var(--white);
  border-radius: 12px;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--gray-200);
  overflow-x: auto;
  margin-bottom: 24px;
}

.patients-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
}

.patients-table th {
  text-align: left;
  padding: 16px 12px;
  background: var(--gray-50);
  color: var(--gray-600);
  font-weight: 600;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  border-bottom: 1px solid var(--gray-200);
  white-space: nowrap;
}

.patients-table td {
  padding: 16px 12px;
  border-bottom: 1px solid var(--gray-100);
  vertical-align: top;
}

.patient-row:hover {
  background: var(--avail-bg-secondary);
}

.patient-info {
  display: flex;
  align-items: center;
  gap: 12px;
  min-width: 200px;
}

.patient-avatar {
  width: 40px;
  height: 40px;
  background: var(--avail-primary);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-size: 12px;
  flex-shrink: 0;
}

.patient-details {
  flex: 1;
}

.patient-name {
  font-weight: 600;
  color: var(--gray-900);
  margin-bottom: 2px;
}

.patient-meta {
  font-size: 12px;
  color: var(--gray-500);
  margin-bottom: 2px;
}

.patient-contact {
  font-size: 12px;
  color: var(--avail-primary);
}

.program-info,
.revenue-info,
.labs-status,
.next-contact {
  min-width: 120px;
}

.program-name,
.revenue-amount {
  font-weight: 600;
  color: var(--gray-900);
  margin-bottom: 2px;
}

.program-duration,
.revenue-ltv {
  font-size: 12px;
  color: var(--gray-500);
}

.labs-result {
  font-size: 12px;
  padding: 2px 6px;
  border-radius: 4px;
  font-weight: 500;
}

.labs-result.good {
  background: rgba(107, 142, 90, 0.1);
  color: var(--avail-success);
}

.labs-result.pending {
  background: rgba(212, 165, 116, 0.15);
  color: var(--avail-warning);
}

.labs-result.needs-action,
.labs-result.overdue {
  background: rgba(184, 84, 80, 0.1);
  color: var(--avail-error);
}

.adherence-section {
  min-width: 100px;
}

.adherence-bar {
  width: 60px;
  height: 6px;
  background: var(--gray-200);
  border-radius: 3px;
  overflow: hidden;
  margin-bottom: 4px;
}

.adherence-fill {
  height: 100%;
  background: var(--avail-success);
  border-radius: 3px;
  transition: width 0.3s ease;
}

.adherence-score {
  font-weight: 600;
  font-size: 12px;
  color: var(--gray-900);
}

.adherence-trend {
  font-size: 11px;
  font-weight: 500;
}

.adherence-trend.good {
  color: var(--avail-success);
}

.adherence-trend.ok {
  color: var(--avail-warning);
}

.adherence-trend.poor {
  color: var(--avail-error);
}

.contact-date {
  font-weight: 500;
  color: var(--gray-900);
  margin-bottom: 2px;
}

.contact-type {
  font-size: 12px;
  color: var(--gray-500);
}

.action-buttons {
  display: flex;
  gap: 4px;
  justify-content: center;
}

.action-btn {
  width: 28px;
  height: 28px;
  padding: 0;
  border: 1px solid var(--gray-300);
  background: var(--white);
  color: var(--gray-600);
  border-radius: 4px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.action-btn:hover {
  background: var(--avail-primary);
  color: var(--white);
  border-color: var(--avail-primary);
}

.action-btn.primary {
  background: var(--avail-primary);
  color: var(--white);
  border-color: var(--avail-primary);
}

.action-btn.warning {
  background: var(--avail-warning);
  color: var(--white);
  border-color: var(--avail-warning);
}

.patient-analytics {
  margin-top: 24px;
}

.analytics-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}

.analytics-card {
  background: var(--white);
  padding: 24px;
  border-radius: 12px;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--gray-200);
}

.analytics-card h3 {
  margin: 0 0 20px;
  color: var(--gray-900);
  font-size: 16px;
  font-weight: 600;
}

.retention-metrics {
  display: flex;
  gap: 24px;
}

.metric {
  text-align: center;
}

.metric-value {
  display: block;
  font-size: 24px;
  font-weight: 700;
  color: var(--avail-primary);
  margin-bottom: 4px;
}

.metric-label {
  display: block;
  font-size: 12px;
  color: var(--gray-600);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.outcome-summary {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.outcome-stat {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.outcome-label {
  color: var(--gray-600);
  font-size: 14px;
}

.outcome-value {
  color: var(--avail-primary);
  font-weight: 600;
  font-size: 14px;
}

@media (max-width: 768px) {
  .search-section {
    flex-direction: column;
    align-items: stretch;
  }
  
  .patients-table-container {
    overflow-x: scroll;
  }
  
  .analytics-grid {
    grid-template-columns: 1fr;
  }
  
  .retention-metrics {
    justify-content: space-around;
  }
}
</style>