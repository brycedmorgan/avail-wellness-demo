<style>
/* Billing-specific styles */
.billing-table-container {
    background: var(--white);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
}

.billing-table {
    width: 100%;
    border-collapse: collapse;
}

.billing-table th {
    background: var(--avail-bg-accent);
    padding: 16px 12px;
    text-align: left;
    font-weight: 600;
    color: var(--avail-text-primary);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid var(--gray-200);
}

.billing-table td {
    padding: 16px 12px;
    border-bottom: 1px solid var(--gray-100);
    vertical-align: top;
}

.billing-row:last-child td {
    border-bottom: none;
}

.billing-row.overdue-high {
    border-left: 4px solid #EF4444;
}

.billing-row.overdue-medium {
    border-left: 4px solid #F59E0B;
}

.billing-row.overdue-low {
    border-left: 4px solid #6B7280;
}

.invoice-number {
    font-family: monospace;
    font-weight: 600;
    color: var(--avail-text-primary);
}

.service-type {
    color: var(--avail-text-light);
    font-size: 12px;
}

.amount {
    font-weight: 700;
    color: var(--avail-primary);
    font-size: 16px;
}

.days-overdue {
    padding: 4px 8px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
}

.days-overdue.high {
    background: rgba(239, 68, 68, 0.1);
    color: #DC2626;
}

.days-overdue.medium {
    background: rgba(245, 158, 11, 0.1);
    color: #D97706;
}

.days-overdue.low {
    background: rgba(107, 114, 128, 0.1);
    color: #4B5563;
}

.payment-method {
    color: var(--avail-text-secondary);
    font-size: 13px;
}

.badge.warning {
    background: rgba(245, 158, 11, 0.1);
    color: #D97706;
}

.revenue-charts {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 24px;
}

.chart-card,
.breakdown-card {
    background: var(--white);
    padding: 24px;
    border-radius: 8px;
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
}

.chart-card h4,
.breakdown-card h4 {
    margin: 0 0 16px;
    color: var(--avail-text-primary);
    font-weight: 600;
}

.revenue-breakdown {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.breakdown-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.item-label {
    font-weight: 500;
    color: var(--avail-text-primary);
    font-size: 14px;
}

.item-bar {
    height: 8px;
    background: var(--gray-200);
    border-radius: 4px;
    overflow: hidden;
}

.bar-fill {
    height: 100%;
    background: var(--avail-primary);
    border-radius: 4px;
    transition: width 0.3s ease;
}

.item-value {
    font-weight: 600;
    color: var(--avail-text-primary);
    font-size: 13px;
}

.payment-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
}

.payment-card {
    background: var(--white);
    padding: 20px;
    border-radius: 8px;
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
}

.payment-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
}

.payment-header h4 {
    margin: 0;
    color: var(--avail-text-primary);
    font-weight: 600;
}

.payment-percentage {
    font-size: 20px;
    font-weight: 700;
    color: var(--avail-primary);
}

.payment-amount {
    font-size: 24px;
    font-weight: 700;
    color: var(--avail-text-primary);
    margin-bottom: 4px;
}

.payment-info {
    color: var(--avail-text-secondary);
    font-size: 13px;
    margin-bottom: 6px;
}

.payment-plans {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.plan-card {
    display: flex;
    align-items: center;
    gap: 20px;
    background: var(--white);
    padding: 20px;
    border-radius: 8px;
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
}

.plan-patient {
    min-width: 120px;
}

.plan-patient .patient-name {
    font-weight: 600;
    color: var(--avail-text-primary);
}

.plan-patient .patient-id {
    color: var(--avail-text-light);
    font-size: 11px;
}

.plan-details {
    flex: 1;
}

.plan-amount {
    font-weight: 700;
    color: var(--avail-primary);
    font-size: 16px;
    margin-bottom: 4px;
}

.plan-schedule {
    color: var(--avail-text-secondary);
    font-size: 13px;
    margin-bottom: 8px;
}

.progress-bar {
    height: 6px;
    background: var(--gray-200);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 4px;
}

.progress-fill {
    height: 100%;
    background: var(--avail-success);
    border-radius: 3px;
    transition: width 0.3s ease;
}

.progress-text {
    font-size: 11px;
    color: var(--avail-text-light);
}

.plan-status {
    min-width: 140px;
    text-align: center;
}

.status-badge.current {
    background: rgba(59, 130, 246, 0.1);
    color: #2563EB;
}

.status-badge.complete {
    background: rgba(107, 142, 90, 0.1);
    color: var(--avail-success);
}

.next-payment,
.completion-date {
    font-size: 11px;
    color: var(--avail-text-light);
    margin-top: 4px;
}

.plan-actions {
    display: flex;
    gap: 8px;
}

@media (max-width: 768px) {
    .admin-stats-grid {
        grid-template-columns: 1fr;
    }
    
    .billing-table-container {
        overflow-x: auto;
    }
    
    .billing-table {
        min-width: 900px;
    }
    
    .revenue-charts {
        grid-template-columns: 1fr;
    }
    
    .payment-stats-grid {
        grid-template-columns: 1fr;
    }
    
    .plan-card {
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
    }
    
    .plan-status {
        width: 100%;
        text-align: left;
    }
    
    .plan-actions {
        width: 100%;
    }
}
</style>

<script>
// Revenue Chart
document.addEventListener('DOMContentLoaded', function() {
    const ctx = document.getElementById('revenueChart').getContext('2d');
    const revenueChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: ['Oct', 'Nov', 'Dec', 'Jan', 'Feb', 'Mar'],
            datasets: [{
                label: 'Monthly Revenue',
                data: [38200, 41500, 35800, 42300, 42700, 47850],
                backgroundColor: 'rgba(184, 160, 130, 0.1)',
                borderColor: 'rgba(184, 160, 130, 0.8)',
                borderWidth: 3,
                fill: true,
                tension: 0.4,
                pointBackgroundColor: 'rgba(184, 160, 130, 1)',
                pointBorderColor: 'white',
                pointBorderWidth: 2,
                pointRadius: 6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    display: false
                }
            },
            scales: {
                x: {
                    grid: { display: false }
                },
                y: {
                    beginAtZero: true,
                    ticks: {
                        callback: function(value) {
                            return '$' + (value / 1000) + 'K';
                        }
                    }
                }
            }
        }
    });
});
</script>