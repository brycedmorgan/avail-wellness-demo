<style>
/* Lab management specific styles */
.labs-table-container {
    background: var(--white);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
}

.labs-table {
    width: 100%;
    border-collapse: collapse;
}

.labs-table th {
    background: var(--avail-bg-accent);
    padding: 16px 12px;
    text-align: left;
    font-weight: 600;
    color: var(--avail-text-primary);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid var(--gray-200);
}

.labs-table td {
    padding: 16px 12px;
    border-bottom: 1px solid var(--gray-100);
    vertical-align: top;
}

.lab-row:last-child td {
    border-bottom: none;
}

.lab-row.priority-high {
    border-left: 4px solid #EF4444;
}

.lab-row.priority-medium {
    border-left: 4px solid #F59E0B;
}

.critical-values {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.value {
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
}

.value.high {
    background: rgba(239, 68, 68, 0.1);
    color: #DC2626;
}

.value.low {
    background: rgba(59, 130, 246, 0.1);
    color: #2563EB;
}

.value.borderline {
    background: rgba(245, 158, 11, 0.1);
    color: #D97706;
}

.value.optimal {
    background: rgba(107, 142, 90, 0.1);
    color: var(--avail-success);
}

.priority-badge {
    padding: 4px 8px;
    border-radius: 12px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    text-align: center;
}

.priority-badge.high {
    background: rgba(239, 68, 68, 0.1);
    color: #DC2626;
}

.priority-badge.medium {
    background: rgba(245, 158, 11, 0.1);
    color: #D97706;
}

.priority-badge.routine {
    background: rgba(107, 142, 90, 0.1);
    color: var(--avail-success);
}

.badge {
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
}

.badge.urgent {
    background: rgba(239, 68, 68, 0.1);
    color: #DC2626;
}

.stat-trend.urgent {
    color: #DC2626;
    font-weight: 600;
}

.stat-trend.attention {
    color: #D97706;
    font-weight: 600;
}

.lab-schedule {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
}

.schedule-day {
    background: var(--white);
    border-radius: 8px;
    border: 1px solid var(--gray-200);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
}

.day-header {
    background: var(--avail-primary);
    color: white;
    padding: 16px;
    text-align: center;
}

.day-name {
    font-weight: 600;
    font-size: 16px;
}

.day-date {
    font-size: 14px;
    opacity: 0.9;
    margin: 2px 0;
}

.day-count {
    font-size: 12px;
    opacity: 0.8;
}

.lab-appointments {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.lab-appointment {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    background: var(--avail-bg-secondary);
    border-radius: 6px;
    border-left: 3px solid var(--avail-secondary);
}

.appointment-time {
    font-weight: 600;
    color: var(--avail-primary);
    min-width: 60px;
    font-size: 13px;
}

.lab-appointment .patient-name {
    font-weight: 600;
    color: var(--avail-text-primary);
    min-width: 120px;
}

.test-list {
    color: var(--avail-text-secondary);
    font-size: 13px;
    flex: 1;
}

.analytics-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 24px;
}

.chart-card,
.metrics-card {
    background: var(--white);
    padding: 24px;
    border-radius: 8px;
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
}

.chart-card h4,
.metrics-card h4 {
    margin: 0 0 16px;
    color: var(--avail-text-primary);
    font-weight: 600;
}

.test-metrics {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.test-metric {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px;
    background: var(--avail-bg-secondary);
    border-radius: 6px;
}

.test-name {
    font-weight: 500;
    color: var(--avail-text-primary);
}

.test-count {
    font-weight: 700;
    color: var(--avail-primary);
}

.test-percentage {
    color: var(--avail-text-light);
    font-size: 12px;
}

@media (max-width: 768px) {
    .admin-stats-grid {
        grid-template-columns: 1fr;
    }
    
    .labs-table-container {
        overflow-x: auto;
    }
    
    .labs-table {
        min-width: 1000px;
    }
    
    .analytics-grid {
        grid-template-columns: 1fr;
    }
    
    .lab-schedule {
        grid-template-columns: 1fr;
    }
}
</style>

<script>
// Lab Volume Chart
document.addEventListener('DOMContentLoaded', function() {
    const ctx = document.getElementById('labVolumeChart').getContext('2d');
    const labChart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
            datasets: [{
                label: 'Lab Tests Completed',
                data: [156, 189, 201, 167, 0, 0],
                backgroundColor: 'rgba(184, 160, 130, 0.8)',
                borderColor: 'rgba(184, 160, 130, 1)',
                borderWidth: 1,
                borderRadius: 4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    display: false
                }
            },
            scales: {
                x: {
                    grid: { display: false }
                },
                y: {
                    beginAtZero: true,
                    grid: { color: 'rgba(107, 114, 128, 0.1)' }
                }
            }
        }
    });
});
</script>