---
layout: base.njk
title: Appointments
subtitle: Schedule and manage your appointments with Avail Wellness
---

<!-- Upcoming Appointments -->
<div class="appointments-hero">
    <div class="next-appointment">
        <h3>Your Next Appointment</h3>
        <div class="appointment-card-large">
            <div class="appointment-date-large">
                <div class="date-month">APRIL</div>
                <div class="date-day">15</div>
                <div class="date-year">2026</div>
            </div>
            <div class="appointment-info">
                <h4>{{ patient.appointments.upcoming[0].type }}</h4>
                <div class="appointment-time">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
                    </svg>
                    {{ patient.appointments.upcoming[0].time }}
                </div>
                <div class="appointment-provider">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2zm9 7h-6v13h-2v-6h-2v6H9V9H3V7h18v2z"/>
                    </svg>
                    {{ patient.appointments.upcoming[0].provider }}
                </div>
                <div class="appointment-purpose">{{ patient.appointments.upcoming[0].purpose }}</div>
            </div>
            <div class="appointment-actions-large">
                <button class="btn btn-primary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/>
                    </svg>
                    Join Video Call
                </button>
                <button class="btn btn-outline">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M7 10l5 5 5-5z"/>
                    </svg>
                    Reschedule
                </button>
                <button class="btn btn-outline">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                    </svg>
                    Send Message
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Quick Scheduling -->
<div class="dashboard-grid">
    <div class="dashboard-section">
        <h3>Schedule New Appointment</h3>
        <div class="scheduling-form">
            <div class="form-group">
                <label>Appointment Type</label>
                <select class="form-select">
                    <option>Follow-up Consultation</option>
                    <option>Pellet Insertion</option>
                    <option>Lab Review</option>
                    <option>Initial Consultation</option>
                    <option>Weight Loss Consultation</option>
                </select>
            </div>
            
            <div class="form-group">
                <label>Preferred Provider</label>
                <select class="form-select">
                    <option>Brooke Welsh, WHNP</option>
                    <option>Any Available Provider</option>
                </select>
            </div>
            
            <div class="form-group">
                <label>Preferred Date Range</label>
                <div class="date-inputs">
                    <input type="date" class="form-input" value="2026-04-20">
                    <span class="date-separator">to</span>
                    <input type="date" class="form-input" value="2026-05-05">
                </div>
            </div>
            
            <div class="form-group">
                <label>Time Preference</label>
                <div class="time-options">
                    <label class="checkbox-option">
                        <input type="checkbox" checked>
                        <span class="checkmark"></span>
                        Morning (8 AM - 12 PM)
                    </label>
                    <label class="checkbox-option">
                        <input type="checkbox" checked>
                        <span class="checkmark"></span>
                        Afternoon (12 PM - 5 PM)
                    </label>
                    <label class="checkbox-option">
                        <input type="checkbox">
                        <span class="checkmark"></span>
                        Evening (5 PM - 7 PM)
                    </label>
                </div>
            </div>
            
            <button class="btn btn-primary btn-full">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.1 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"/>
                </svg>
                Find Available Times
            </button>
        </div>
    </div>
    
    <div class="dashboard-section">
        <h3>Available This Week</h3>
        <div class="available-slots">
            <div class="day-slots">
                <div class="day-header">
                    <div class="day-name">Tuesday</div>
                    <div class="day-date">April 1</div>
                </div>
                <div class="time-slots">
                    <button class="time-slot">9:00 AM</button>
                    <button class="time-slot">2:30 PM</button>
                    <button class="time-slot">4:00 PM</button>
                </div>
            </div>
            
            <div class="day-slots">
                <div class="day-header">
                    <div class="day-name">Wednesday</div>
                    <div class="day-date">April 2</div>
                </div>
                <div class="time-slots">
                    <button class="time-slot">10:30 AM</button>
                    <button class="time-slot">3:15 PM</button>
                </div>
            </div>
            
            <div class="day-slots">
                <div class="day-header">
                    <div class="day-name">Friday</div>
                    <div class="day-date">April 4</div>
                </div>
                <div class="time-slots">
                    <button class="time-slot">8:30 AM</button>
                    <button class="time-slot">11:00 AM</button>
                    <button class="time-slot">1:45 PM</button>
                </div>
            </div>
        </div>
        
        <button class="btn btn-outline btn-full" style="margin-top: 16px;">
            View Full Calendar
        </button>
    </div>
</div>

<!-- Appointment History -->
<div class="dashboard-section">
    <h3>Appointment History</h3>
    <div class="history-list">
        {% for appointment in patient.appointments.past %}
        <div class="history-item">
            <div class="history-date">
                <div class="date-month">{{ appointment.date | dateFormat | truncate(3, true, '') | upper }}</div>
                <div class="date-day">{{ appointment.date.split('-')[2] }}</div>
            </div>
            <div class="history-details">
                <div class="history-type">{{ appointment.type }}</div>
                <div class="history-provider">{{ appointment.provider }}</div>
                <div class="history-time">{{ appointment.time }}</div>
                {% if appointment.notes %}
                <div class="history-notes">{{ appointment.notes }}</div>
                {% endif %}
            </div>
            <div class="history-status completed">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                </svg>
                Completed
            </div>
            <div class="history-actions">
                <button class="btn btn-sm btn-outline">View Notes</button>
                <button class="btn btn-sm btn-outline">Schedule Follow-up</button>
            </div>
        </div>
        {% endfor %}
        
        <!-- Additional history items for demo -->
        <div class="history-item">
            <div class="history-date">
                <div class="date-month">DEC</div>
                <div class="date-day">18</div>
            </div>
            <div class="history-details">
                <div class="history-type">Lab Review Consultation</div>
                <div class="history-provider">Brooke Welsh, WHNP</div>
                <div class="history-time">10:00 AM</div>
                <div class="history-notes">Reviewed December lab results, discussed treatment options</div>
            </div>
            <div class="history-status completed">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                </svg>
                Completed
            </div>
            <div class="history-actions">
                <button class="btn btn-sm btn-outline">View Notes</button>
                <button class="btn btn-sm btn-outline">Schedule Follow-up</button>
            </div>
        </div>
        
        <div class="history-item">
            <div class="history-date">
                <div class="date-month">MAR</div>
                <div class="date-day">15</div>
            </div>
            <div class="history-details">
                <div class="history-type">Initial Hormone Consultation</div>
                <div class="history-provider">Brooke Welsh, WHNP</div>
                <div class="history-time">2:00 PM</div>
                <div class="history-notes">Comprehensive evaluation, baseline labs ordered, treatment plan discussed</div>
            </div>
            <div class="history-status completed">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                </svg>
                Completed
            </div>
            <div class="history-actions">
                <button class="btn btn-sm btn-outline">View Notes</button>
                <button class="btn btn-sm btn-outline">Schedule Follow-up</button>
            </div>
        </div>
    </div>
</div>

<!-- Appointment Preferences -->
<div class="dashboard-section">
    <h3>Appointment Preferences</h3>
    <div class="preferences-form">
        <div class="preference-group">
            <h4>Communication Preferences</h4>
            <div class="preference-options">
                <label class="checkbox-option">
                    <input type="checkbox" checked>
                    <span class="checkmark"></span>
                    Email reminders (24 hours before)
                </label>
                <label class="checkbox-option">
                    <input type="checkbox" checked>
                    <span class="checkmark"></span>
                    Text message reminders (2 hours before)
                </label>
                <label class="checkbox-option">
                    <input type="checkbox">
                    <span class="checkmark"></span>
                    Phone call reminders (1 day before)
                </label>
            </div>
        </div>
        
        <div class="preference-group">
            <h4>Scheduling Preferences</h4>
            <div class="preference-options">
                <label class="checkbox-option">
                    <input type="checkbox" checked>
                    <span class="checkmark"></span>
                    Same-day appointments (when available)
                </label>
                <label class="checkbox-option">
                    <input type="checkbox" checked>
                    <span class="checkmark"></span>
                    Automatic follow-up scheduling
                </label>
                <label class="checkbox-option">
                    <input type="checkbox">
                    <span class="checkmark"></span>
                    Waitlist for earlier appointments
                </label>
            </div>
        </div>
        
        <button class="btn btn-primary">Save Preferences</button>
    </div>
</div>

<style>
/* Appointment page styles */
.appointments-hero {
    margin-bottom: 32px;
}

.next-appointment h3 {
    margin: 0 0 20px;
    color: var(--avail-text-primary);
    font-size: 24px;
    font-weight: 600;
}

.appointment-card-large {
    display: flex;
    align-items: center;
    gap: 24px;
    background: var(--avail-primary);
    color: white;
    padding: 32px;
    border-radius: 16px;
    box-shadow: var(--shadow-lg);
}

.appointment-date-large {
    text-align: center;
    background: rgba(255, 255, 255, 0.2);
    padding: 20px;
    border-radius: 12px;
    backdrop-filter: blur(10px);
    min-width: 120px;
}

.date-month {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1px;
    opacity: 0.9;
}

.date-day {
    font-size: 36px;
    font-weight: 700;
    line-height: 1;
    margin: 4px 0;
}

.date-year {
    font-size: 14px;
    opacity: 0.9;
}

.appointment-info {
    flex: 1;
}

.appointment-info h4 {
    font-size: 20px;
    font-weight: 600;
    margin: 0 0 12px;
}

.appointment-time,
.appointment-provider {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    font-size: 14px;
    opacity: 0.9;
}

.appointment-purpose {
    font-size: 14px;
    opacity: 0.8;
    font-style: italic;
}

.appointment-actions-large {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 200px;
}

.scheduling-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.form-group label {
    font-weight: 500;
    color: var(--avail-text-primary);
    font-size: 14px;
}

.form-select,
.form-input {
    padding: 12px;
    border: 1px solid var(--gray-300);
    border-radius: 6px;
    font-size: 14px;
    background: var(--white);
}

.form-select:focus,
.form-input:focus {
    outline: none;
    border-color: var(--avail-primary);
    box-shadow: 0 0 0 3px rgba(184, 160, 130, 0.1);
}

.date-inputs {
    display: flex;
    align-items: center;
    gap: 12px;
}

.date-separator {
    color: var(--gray-500);
    font-size: 14px;
}

.time-options,
.preference-options {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.checkbox-option {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    cursor: pointer;
    color: var(--avail-text-secondary);
}

.checkbox-option input[type="checkbox"] {
    display: none;
}

.checkmark {
    width: 16px;
    height: 16px;
    border: 2px solid var(--gray-300);
    border-radius: 3px;
    position: relative;
    transition: all 0.2s ease;
}

.checkbox-option input[type="checkbox"]:checked + .checkmark {
    background: var(--avail-primary);
    border-color: var(--avail-primary);
}

.checkbox-option input[type="checkbox"]:checked + .checkmark::after {
    content: '✓';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: white;
    font-size: 10px;
    font-weight: bold;
}

.btn-full {
    width: 100%;
    justify-content: center;
}

.available-slots {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.day-slots {
    display: flex;
    align-items: center;
    gap: 12px;
}

.day-header {
    min-width: 80px;
    text-align: center;
}

.day-name {
    font-weight: 600;
    color: var(--avail-text-primary);
    font-size: 14px;
}

.day-date {
    color: var(--avail-text-light);
    font-size: 12px;
}

.time-slots {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.time-slot {
    padding: 6px 12px;
    border: 1px solid var(--gray-300);
    background: var(--white);
    color: var(--avail-text-secondary);
    border-radius: 6px;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s ease;
}

.time-slot:hover {
    background: var(--avail-primary);
    color: white;
    border-color: var(--avail-primary);
}

.history-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.history-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px;
    background: var(--white);
    border-radius: 8px;
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
}

.history-date {
    text-align: center;
    background: var(--avail-bg-accent);
    padding: 12px;
    border-radius: 6px;
    min-width: 60px;
}

.history-date .date-month {
    font-size: 12px;
    font-weight: 600;
    color: var(--avail-primary);
    line-height: 1;
}

.history-date .date-day {
    font-size: 20px;
    font-weight: 700;
    color: var(--avail-text-primary);
    line-height: 1;
}

.history-details {
    flex: 1;
}

.history-type {
    font-weight: 600;
    color: var(--avail-text-primary);
    margin-bottom: 4px;
}

.history-provider {
    color: var(--avail-text-secondary);
    font-size: 14px;
    margin-bottom: 2px;
}

.history-time {
    color: var(--avail-text-light);
    font-size: 12px;
    margin-bottom: 4px;
}

.history-notes {
    color: var(--avail-text-secondary);
    font-size: 13px;
    font-style: italic;
    line-height: 1.4;
}

.history-status {
    display: flex;
    align-items: center;
    gap: 4px;
    color: var(--avail-success);
    font-size: 12px;
    font-weight: 500;
    min-width: 80px;
}

.history-actions {
    display: flex;
    gap: 8px;
}

.preferences-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.preference-group h4 {
    margin: 0 0 12px;
    color: var(--avail-text-primary);
    font-weight: 600;
    font-size: 16px;
}

@media (max-width: 768px) {
    .appointment-card-large {
        flex-direction: column;
        text-align: center;
        gap: 20px;
    }
    
    .appointment-actions-large {
        width: 100%;
    }
    
    .dashboard-grid {
        grid-template-columns: 1fr;
    }
    
    .history-item {
        flex-wrap: wrap;
        gap: 12px;
    }
    
    .history-actions {
        width: 100%;
        justify-content: flex-start;
    }
    
    .day-slots {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
    }
}
</style>

<script>
// Appointment scheduling functionality
document.addEventListener('DOMContentLoaded', function() {
    // Time slot selection
    const timeSlots = document.querySelectorAll('.time-slot');
    
    timeSlots.forEach(slot => {
        slot.addEventListener('click', function() {
            // Remove selected from all slots
            timeSlots.forEach(s => s.classList.remove('selected'));
            // Add selected to clicked slot
            this.classList.add('selected');
            
            // Show confirmation or booking form
            console.log('Selected time:', this.textContent);
        });
    });
    
    // Form submission
    const findTimesBtn = document.querySelector('.btn-primary.btn-full');
    
    findTimesBtn.addEventListener('click', function() {
        const appointmentType = document.querySelector('.form-select').value;
        const startDate = document.querySelector('.form-input').value;
        
        console.log('Finding times for:', appointmentType, 'starting', startDate);
        // In real app, this would search available slots
    });
});

// Add selected state for time slots
const style = document.createElement('style');
style.textContent = `
    .time-slot.selected {
        background: var(--avail-primary) !important;
        color: white !important;
        border-color: var(--avail-primary) !important;
        font-weight: 600;
    }
`;
document.head.appendChild(style);
</script>