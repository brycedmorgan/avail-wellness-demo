---
layout: base.njk
title: Body Composition
subtitle: DEXA scan results and progress tracking
---

<!-- Progress Overview -->
<div class="composition-hero">
    <div class="hero-content">
        <h3>{{ patient.patient.name.split(' ')[0] }}'s Body Transformation</h3>
        <p>Comprehensive DEXA scan analysis showing your body composition changes alongside hormone optimization.</p>
        
        <div class="progress-highlights">
            <div class="highlight-metric">
                <div class="metric-value">-9.8%</div>
                <div class="metric-label">Body Fat Reduction</div>
            </div>
            <div class="highlight-metric">
                <div class="metric-value">+9.8 lbs</div>
                <div class="metric-label">Lean Mass Gained</div>
            </div>
            <div class="highlight-metric">
                <div class="metric-value">-1.7</div>
                <div class="metric-label">Visceral Fat Levels</div>
            </div>
        </div>
    </div>
</div>

<!-- DEXA Scan Comparison -->
<div class="dashboard-section">
    <h3>DEXA Scan Results</h3>
    <div class="scan-comparison">
        {% for scan in patient.bodyComposition %}
        <div class="scan-card">
            <div class="scan-header">
                <h4>{{ scan.date | dateFormat }}</h4>
                <div class="scan-summary">{{ scan.summary }}</div>
            </div>
            
            <div class="composition-metrics">
                <div class="metric-circle">
                    <div class="circle-chart" data-percentage="{{ scan.bodyFatPercentage }}">
                        <div class="circle-inner">
                            <div class="percentage">{{ scan.bodyFatPercentage }}%</div>
                            <div class="label">Body Fat</div>
                        </div>
                    </div>
                </div>
                
                <div class="detailed-metrics">
                    <div class="metric-row">
                        <span class="metric-name">Lean Mass:</span>
                        <span class="metric-value">{{ scan.leanMass }} kg</span>
                    </div>
                    <div class="metric-row">
                        <span class="metric-name">Visceral Fat:</span>
                        <span class="metric-value">{{ scan.visceralFat }}</span>
                    </div>
                    <div class="metric-row">
                        <span class="metric-name">Bone Density:</span>
                        <span class="metric-value">{{ scan.boneDensity }} g/cm²</span>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>

<!-- Progress Charts -->
<div class="dashboard-section">
    <h3>Body Composition Trends</h3>
    <div class="chart-container">
        <canvas id="bodyCompositionChart" width="800" height="300"></canvas>
    </div>
</div>

<!-- Correlation with Hormone Levels -->
<div class="dashboard-section">
    <h3>Hormone Correlation Analysis</h3>
    <div class="correlation-insights">
        <div class="insight-card">
            <h4>Key Findings</h4>
            <ul>
                <li><strong>Testosterone Optimization Impact:</strong> Your testosterone increase from 281 to 853 ng/dl correlates directly with the 9.8% body fat reduction.</li>
                <li><strong>Muscle Preservation:</strong> Lean mass increased by 9.8 lbs while losing fat - indicating proper hormone balance.</li>
                <li><strong>Visceral Fat Improvement:</strong> Dangerous visceral fat reduced from 3.8 to 2.1 - excellent cardiovascular benefit.</li>
                <li><strong>Bone Health:</strong> Bone density improved from 1.12 to 1.18 g/cm² - testosterone supports bone strength.</li>
            </ul>
        </div>
    </div>
</div>

<style>
.composition-hero {
    background: var(--avail-primary);
    color: white;
    padding: 32px;
    border-radius: 16px;
    margin-bottom: 32px;
    box-shadow: var(--shadow-lg);
}

.hero-content h3 {
    font-size: 24px;
    font-weight: 600;
    margin: 0 0 8px;
}

.hero-content p {
    opacity: 0.9;
    margin: 0 0 24px;
    font-size: 16px;
}

.progress-highlights {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 20px;
}

.highlight-metric {
    text-align: center;
    background: rgba(255, 255, 255, 0.1);
    padding: 20px;
    border-radius: 8px;
}

.metric-value {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 4px;
}

.metric-label {
    font-size: 14px;
    opacity: 0.9;
}

.scan-comparison {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 24px;
}

.scan-card {
    background: var(--avail-bg-secondary);
    padding: 24px;
    border-radius: 12px;
    border: 2px solid var(--gray-200);
}

.scan-header {
    margin-bottom: 20px;
    text-align: center;
}

.scan-header h4 {
    margin: 0 0 4px;
    color: var(--avail-text-primary);
    font-weight: 600;
}

.scan-summary {
    font-size: 14px;
    color: var(--avail-text-secondary);
}

.composition-metrics {
    display: flex;
    align-items: center;
    gap: 24px;
}

.metric-circle {
    flex-shrink: 0;
}

.circle-chart {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: conic-gradient(var(--avail-primary) 0deg 100deg, var(--gray-200) 100deg 360deg);
    display: flex;
    align-items: center;
    justify-content: center;
}

.circle-inner {
    width: 90px;
    height: 90px;
    background: white;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.percentage {
    font-size: 20px;
    font-weight: 700;
    color: var(--avail-primary);
}

.label {
    font-size: 12px;
    color: var(--gray-600);
}

.detailed-metrics {
    flex: 1;
}

.metric-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--gray-200);
}

.metric-name {
    color: var(--avail-text-secondary);
    font-size: 14px;
}

.metric-value {
    color: var(--avail-text-primary);
    font-weight: 600;
    font-size: 14px;
}

.correlation-insights {
    background: var(--avail-bg-accent);
    padding: 24px;
    border-radius: 8px;
    border-left: 4px solid var(--avail-success);
}

.insight-card h4 {
    margin: 0 0 16px;
    color: var(--avail-text-primary);
}

.insight-card ul {
    margin: 0;
    padding-left: 20px;
}

.insight-card li {
    margin-bottom: 12px;
    color: var(--avail-text-secondary);
    line-height: 1.6;
}

@media (max-width: 768px) {
    .composition-metrics {
        flex-direction: column;
        text-align: center;
    }
    
    .scan-comparison {
        grid-template-columns: 1fr;
    }
}
</style>

<script>
// Body Composition Chart
const ctx = document.getElementById('bodyCompositionChart').getContext('2d');
const bodyChart = new Chart(ctx, {
    type: 'line',
    data: {
        labels: ['January 2024', 'August 2025'],
        datasets: [{
            label: 'Body Fat %',
            data: [31.1, 21.3],
            backgroundColor: 'rgba(184, 160, 130, 0.1)',
            borderColor: 'rgba(184, 160, 130, 0.8)',
            borderWidth: 3,
            fill: true,
            tension: 0.4,
            pointBackgroundColor: 'rgba(184, 160, 130, 1)',
            pointBorderColor: 'white',
            pointBorderWidth: 2,
            pointRadius: 8
        }, {
            label: 'Lean Mass (kg)',
            data: [68.9, 78.7],
            backgroundColor: 'rgba(107, 142, 90, 0.1)',
            borderColor: 'rgba(107, 142, 90, 0.8)',
            borderWidth: 3,
            fill: true,
            tension: 0.4,
            pointBackgroundColor: 'rgba(107, 142, 90, 1)',
            pointBorderColor: 'white',
            pointBorderWidth: 2,
            pointRadius: 8,
            yAxisID: 'y1'
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                position: 'bottom'
            }
        },
        scales: {
            x: {
                grid: { display: false }
            },
            y: {
                type: 'linear',
                display: true,
                position: 'left',
                title: {
                    display: true,
                    text: 'Body Fat %'
                }
            },
            y1: {
                type: 'linear',
                display: true,
                position: 'right',
                title: {
                    display: true,
                    text: 'Lean Mass (kg)'
                },
                grid: { drawOnChartArea: false }
            }
        }
    }
});
</script>