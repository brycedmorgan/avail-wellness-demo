<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - Avail Wellness Portal</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/avail-brand.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="app-container">
        <!-- Navigation -->
        <nav class="sidebar">
            <div class="logo">
                <img src="/images/avail-logo-real.png" alt="Avail Wellness" class="logo-img">
            </div>
            
            <div class="nav-menu">
                <a href="/" class="nav-item {% if page.url == '/' %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
                    </svg>
                    Dashboard
                </a>
                <a href="/labs/" class="nav-item {% if '/labs/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M9 2v3h2V2h2v3h2V2h2v5H7V2h2zm8 8.5c0 .55-.45 1-1 1s-1-.45-1-1 .45-1 1-1 1 .45 1 1zM9 12c.55 0 1-.45 1-1s-.45-1-1-1-1 .45-1 1 .45 1 1 1zm3 9.5L8.5 18c-.28 0-.5-.22-.5-.5s.22-.5.5-.5l3.5 3.5z"/>
                    </svg>
                    Lab Results
                </a>
                <a href="/body-composition/" class="nav-item {% if '/body-composition/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M5 9.2h3V19H5zM10.6 5h2.8v14h-2.8zm5.6 8H19v6h-2.8z"/>
                    </svg>
                    Body Composition
                </a>
                <a href="/supplements/" class="nav-item {% if '/supplements/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M3.5 6L2 7.5 7.5 13 2 18.5 3.5 20l5.5-5.5L14.5 20 16 18.5 10.5 13 16 7.5 14.5 6 9 11.5 3.5 6zM20.5 6c-.83 0-1.5.67-1.5 1.5v9c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5v-9c0-.83-.67-1.5-1.5-1.5z"/>
                    </svg>
                    Supplements
                </a>
                <a href="/treatments/" class="nav-item {% if '/treatments/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M19 8h-2v3h-3v2h3v3h2v-3h3v-2h-3V8zM4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H8V4h12v12z"/>
                    </svg>
                    Treatments
                </a>
                <a href="/appointments/" class="nav-item {% if '/appointments/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.1 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"/>
                    </svg>
                    Appointments
                </a>
                <a href="/billing/" class="nav-item {% if '/billing/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/>
                    </svg>
                    Billing
                </a>
            </div>
            
            <div class="nav-footer">
                <div class="user-profile">
                    <div class="user-avatar">BM</div>
                    <div class="user-info">
                        <div class="user-name">{{ patient.patient.name }}</div>
                        <div class="user-role">Patient</div>
                    </div>
                </div>
                <div class="portal-switch">
                    <a href="/admin/" class="switch-link">
                        <svg class="switch-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"/>
                        </svg>
                        View Provider Portal
                    </a>
                </div>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="main-content">
            <header class="page-header">
                <div class="header-welcome">
                    <div class="welcome-message">Welcome back, {{ patient.patient.name.split(' ')[0] }}! 👋</div>
                </div>
                <h1>{{ title }}</h1>
                {% if subtitle %}
                <p class="page-subtitle">{{ subtitle }}</p>
                {% endif %}
            </header>
            
            <div class="content">
                {{ content | safe }}
            </div>
        </main>
    </div>
    
    <script src="/js/app.js"></script>
</body>
</html>