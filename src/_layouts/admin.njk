<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - Avail Wellness Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="/css/avail-brand.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="admin-theme">
    <div class="admin-container">
        <!-- Admin Navigation -->
        <nav class="admin-sidebar">
            <div class="logo">
                <img src="/images/avail-logo-real.png" alt="Avail Wellness" class="logo-img">
                <div class="logo-text">
                    <span class="admin-badge">Admin Portal</span>
                </div>
            </div>
            
            <div class="nav-menu">
                <a href="/admin/" class="nav-item {% if page.url == '/admin/' %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/>
                    </svg>
                    Dashboard
                </a>
                <a href="/admin/patients/" class="nav-item {% if '/admin/patients/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M16 4c0-1.11.89-2 2-2s2 .89 2 2-.89 2-2 2-2-.89-2-2zm4 18v-6h2.5l-2.54-7.63c-.34-1.02-1.3-1.74-2.46-1.74s-2.12.72-2.46 1.74L12.5 16H15v6h5zM12.5 11.5c.83 0 1.5-.67 1.5-1.5s-.67-1.5-1.5-1.5S11 9.17 11 10s.67 1.5 1.5 1.5zM5.5 6c1.11 0 2-.89 2-2s-.89-2-2-2-2 .89-2 2 .89 2 2 2zm1.5 2h-3C2.67 8 2 8.67 2 9.5v7h2v7h4v-7h2v-7C10 8.67 9.33 8 8.5 8z"/>
                    </svg>
                    Patients
                </a>
                <a href="/admin/appointments/" class="nav-item {% if '/admin/appointments/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.1 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"/>
                    </svg>
                    Calendar
                </a>
                <a href="/admin/labs/" class="nav-item {% if '/admin/labs/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M9 2v3h2V2h2v3h2V2h2v5H7V2h2zm8 8.5c0 .55-.45 1-1 1s-1-.45-1-1 .45-1 1-1 1 .45 1 1zM9 12c.55 0 1-.45 1-1s-.45-1-1-1-1 .45-1 1 .45 1 1 1zm3 9.5L8.5 18c-.28 0-.5-.22-.5-.5s.22-.5.5-.5l3.5 3.5zm1.5-3.5L11 15.5c-.28 0-.5-.22-.5-.5s.22-.5.5-.5L13.5 18zM20 8.69L18.31 7l-1.5 1.5L15.31 7 14 8.31l1.5 1.5L14 11.31 15.31 12.62 16.81 11.12 18.31 12.62 19.62 11.31 18.12 9.81 19.62 8.31z"/>
                    </svg>
                    Labs & Results
                </a>
                <a href="/admin/billing/" class="nav-item {% if '/admin/billing/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/>
                    </svg>
                    Billing
                </a>
                <a href="/admin/inventory/" class="nav-item {% if '/admin/inventory/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
                    </svg>
                    Inventory
                </a>
                <a href="/admin/leads/" class="nav-item {% if '/admin/leads/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                    </svg>
                    Leads
                </a>
                <a href="/admin/analytics/" class="nav-item {% if '/admin/analytics/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M5 9.2h3V19H5zM10.6 5h2.8v14h-2.8zm5.6 8H19v6h-2.8z"/>
                    </svg>
                    Analytics
                </a>
            </div>
            
            <div class="nav-footer">
                <div class="admin-profile">
                    <div class="user-avatar provider">BW</div>
                    <div class="user-info">
                        <div class="user-name">Brooke Welsh</div>
                        <div class="user-role">Provider • Admin</div>
                    </div>
                </div>
                <div class="portal-switch">
                    <a href="/" class="switch-link">
                        <svg class="switch-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2C13.1 2 14 2.9 14 4C14 5.1 13.1 6 12 6C10.9 6 10 5.1 10 4C10 2.9 10.9 2 12 2ZM21 9V7L15 4V6C15 7.1 14.1 8 13 8H11C9.9 8 9 7.1 9 6V4L3 7V9H21ZM22 16C22 17.1 21.1 18 20 18H4C2.9 18 2 17.1 2 16V10H22V16Z"/>
                        </svg>
                        View Patient Portal
                    </a>
                </div>
            </div>
        </nav>

        <!-- Main Admin Content -->
        <main class="admin-main">
            <header class="admin-header">
                <div class="header-content">
                    <div class="header-title">
                        <div class="admin-welcome">Provider Dashboard - Brooke Welsh, WHNP 👩‍⚕️</div>
                        <h1>{{ title }}</h1>
                        {% if subtitle %}
                        <p class="header-subtitle">{{ subtitle }}</p>
                        {% endif %}
                    </div>
                    <div class="header-actions">
                        <div class="quick-stats">
                            <div class="stat-item">
                                <span class="stat-value">{{ adminData.businessMetrics.activePatients }}</span>
                                <span class="stat-label">Active Patients</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-value">${{ (adminData.businessMetrics.monthlyRevenue / 1000) | round(1) }}K</span>
                                <span class="stat-label">Monthly Revenue</span>
                            </div>
                        </div>
                        <div class="header-buttons">
                            <button class="btn btn-outline btn-sm">
                                <span class="btn-icon">📋</span>
                                Export Report
                            </button>
                            <button class="btn btn-primary btn-sm">
                                <span class="btn-icon">➕</span>
                                Add Patient
                            </button>
                        </div>
                    </div>
                </div>
            </header>
            
            <div class="admin-content">
                {{ content | safe }}
            </div>
        </main>
    </div>
    
    <script src="/js/app.js"></script>
    <script src="/js/admin.js"></script>
</body>
</html>