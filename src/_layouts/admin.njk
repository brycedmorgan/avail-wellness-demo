<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - Avail Wellness Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="/css/avail-brand.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="admin-theme">
    <div class="admin-container">
        <!-- Admin Navigation -->
        <nav class="admin-sidebar">
            <div class="logo">
                <img src="/images/avail-logo-real.png" alt="Avail Wellness" class="logo-img">
                <div class="logo-text">
                    <span class="admin-badge">Provider Portal</span>
                </div>
            </div>
            
            <div class="nav-menu">
                <a href="/admin/" class="nav-item {% if page.url == '/admin/' %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/>
                    </svg>
                    Dashboard
                </a>

                <div class="nav-section-label">AI Tools</div>

                <a href="/admin/protocol-builder/" class="nav-item nav-item-feature {% if '/admin/protocol-builder/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                    Protocol Builder
                    <span class="nav-new">New</span>
                </a>
                <a href="/admin/personas/" class="nav-item nav-item-feature {% if '/admin/personas/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M16 11c1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 3-1.34 3-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                    </svg>
                    Patient Personas
                    <span class="nav-new">New</span>
                </a>
                <a href="/admin/method/" class="nav-item {% if '/admin/method/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
                    </svg>
                    How It Works
                </a>

                <div class="nav-section-label">Patient Care</div>

                <a href="/admin/patients/" class="nav-item {% if '/admin/patients/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M16 4c0-1.11.89-2 2-2s2 .89 2 2-.89 2-2 2-2-.89-2-2zm4 18v-6h2.5l-2.54-7.63c-.34-1.02-1.3-1.74-2.46-1.74s-2.12.72-2.46 1.74L12.5 16H15v6h5zM12.5 11.5c.83 0 1.5-.67 1.5-1.5s-.67-1.5-1.5-1.5S11 9.17 11 10s.67 1.5 1.5 1.5zM5.5 6c1.11 0 2-.89 2-2s-.89-2-2-2-2 .89-2 2 .89 2 2 2zm1.5 2h-3C2.67 8 2 8.67 2 9.5v7h2v7h4v-7h2v-7C10 8.67 9.33 8 8.5 8z"/>
                    </svg>
                    Patients
                </a>
                <a href="/admin/labs/" class="nav-item {% if '/admin/labs/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M9 2v3h2V2h2v3h2V2h2v5H7V2h2zm8 8.5c0 .55-.45 1-1 1s-1-.45-1-1 .45-1 1-1 1 .45 1 1zM9 12c.55 0 1-.45 1-1s-.45-1-1-1-1 .45-1 1 .45 1 1 1z"/>
                    </svg>
                    Labs &amp; Results
                </a>
                <a href="/admin/analytics/" class="nav-item {% if '/admin/analytics/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M5 9.2h3V19H5zM10.6 5h2.8v14h-2.8zm5.6 8H19v6h-2.8z"/>
                    </svg>
                    Analytics
                </a>

                <div class="nav-section-label">Existing systems</div>
                <a href="/admin/appointments/" class="nav-item nav-item-external {% if '/admin/appointments/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.1 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"/></svg>
                    Calendar <span class="nav-ext">EMR</span>
                </a>
                <a href="/admin/billing/" class="nav-item nav-item-external {% if '/admin/billing/' in page.url %}active{% endif %}">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>
                    Billing <span class="nav-ext">EMR</span>
                </a>
            </div>
            
            <div class="nav-footer">
                <div class="admin-profile">
                    <div class="user-avatar provider">BW</div>
                    <div class="user-info">
                        <div class="user-name">Brooke Welsh</div>
                        <div class="user-role">Provider • Admin</div>
                    </div>
                </div>
                <div class="portal-switch">
                    <a href="/" class="switch-link">
                        <svg class="switch-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2C13.1 2 14 2.9 14 4C14 5.1 13.1 6 12 6C10.9 6 10 5.1 10 4C10 2.9 10.9 2 12 2ZM21 9V7L15 4V6C15 7.1 14.1 8 13 8H11C9.9 8 9 7.1 9 6V4L3 7V9H21ZM22 16C22 17.1 21.1 18 20 18H4C2.9 18 2 17.1 2 16V10H22V16Z"/>
                        </svg>
                        View Patient Portal
                    </a>
                </div>
            </div>
        </nav>

        <!-- Main Admin Content -->
        <main class="admin-main">
            <header class="admin-header">
                <div class="header-content">
                    <div class="header-title">
                        <div class="admin-welcome">Provider Dashboard — Brooke Welsh, WHNP</div>
                        <h1>{{ title }}</h1>
                        {% if subtitle %}
                        <p class="header-subtitle">{{ subtitle }}</p>
                        {% endif %}
                    </div>
                    <div class="header-actions">
                        <div class="quick-stats">
                            <div class="stat-item">
                                <span class="stat-value">{{ adminData.businessMetrics.activePatients }}</span>
                                <span class="stat-label">Active Patients</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-value">{{ cohortData.cohorts | length }}</span>
                                <span class="stat-label">Cohorts</span>
                            </div>
                        </div>
                    </div>
                </div>
            </header>
            
            <div class="admin-content">
                {{ content | safe }}
            </div>
        </main>
    </div>
    
    <script src="/js/app.js"></script>
    <script src="/js/admin.js"></script>
</body>
</html>
